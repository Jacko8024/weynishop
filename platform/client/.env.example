VITE_API_URL=http://localhost:5000
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
# Public storefront URL opened by the admin "Go to Website" button.
# In dev this is the same as the dev server; in prod set to your live domain.
VITE_STOREFRONT_URL=http://localhost:5173

# ---- Firebase web config (optional; defaults are baked into src/lib/firebase.js) ----
# Override these only if you point the client at a different Firebase project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
