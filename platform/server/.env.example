# =============================================================================
# WeyniShop server — environment variables (Supabase / Postgres)
# Copy this file to .env and fill in your real values.
# =============================================================================

# --- Supabase Postgres (Sequelize) -------------------------------------------
# From: Supabase dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the *Pooler* string (host: aws-0-<region>.pooler.supabase.com, port 6543)
# for development with nodemon -- direct connections (port 5432) work too but
# may rate-limit on hot-reload.
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DB_SSL=true

# --- Supabase JS client (Storage uploads) ------------------------------------
SUPABASE_URL=https://<ref>.supabase.co
# IMPORTANT: service-role key, NOT the anon key. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...
# Bucket names (must already exist in Supabase Storage and be marked public).
SUPABASE_BUCKET_PRODUCTS=product-images
SUPABASE_BUCKET_BANNERS=banner-images

# --- App ---------------------------------------------------------------------
PORT=5000
JWT_SECRET=change-me-to-something-long-and-random
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
STOREFRONT_URL=http://localhost:5173
GOOGLE_MAPS_API_KEY=

# --- Firebase Admin (for Google sign-in token verification) ------------------
FIREBASE_PROJECT_ID=weynishop
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@weynishop.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
